# =============================================================================
# NextAuth Configuration
# =============================================================================
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (add whichever you use)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# Mainlayer Configuration
# Get your keys at: https://app.mainlayer.xyz
# =============================================================================
# Your secret API key — keep this server-side only
MAINLAYER_API_KEY=ml_your_secret_api_key_here

# The resource ID for your SaaS product (create at mainlayer.xyz)
MAINLAYER_RESOURCE_ID=res_your_resource_id_here

# =============================================================================
# Database (for NextAuth session storage)
# =============================================================================
# Supports PostgreSQL, MySQL, SQLite
DATABASE_URL=postgresql://user:password@localhost:5432/saas_db
